# إعدادات قاعدة البيانات - PostgreSQL Database Settings
DB_NAME=daftarcash_db
DB_USER=daftarcash_user
DB_PASSWORD=your_secure_password
DB_HOST=localhost
DB_PORT=5432

# إعدادات Django الاختيارية (للحماية والإنتاج)
# SECRET_KEY=django-insecure-...
# DEBUG=True

# إعدادات البريد الإلكتروني - SMTP Email Settings
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=your_email@gmail.com
# EMAIL_HOST_PASSWORD=your_app_specific_password
# DEFAULT_FROM_EMAIL=your_email@gmail.com

# إعدادات Infobip للتحقق من البريد الإلكتروني (Infobip API settings for Email verification)
# INFOBIP_API_KEY=your_infobip_api_key_here
# INFOBIP_BASE_URL=your_infobip_base_url_here
# INFOBIP_FROM_EMAIL=Daftar Cash <noreply@yourdomain.com>


# مفتاح الذكاء الاصطناعي لتحليل الرسائل تلقائياً
GEMINI_API_KEY=your_gemini_api_key_here