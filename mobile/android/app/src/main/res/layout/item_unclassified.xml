<?xml version="1.0" encoding="utf-8"?>
<!-- عنصر واحد في قائمة الرسائل غير المصنفة -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/card_dark"
    android:padding="14dp"
    android:layout_marginHorizontal="8dp"
    android:layout_marginVertical="4dp">

    <!-- الصف العلوي: المرسل + الوقت -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/tvSender"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="VodafoneCash"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="12:30"
            android:textColor="#888888"
            android:textSize="11sp" />
    </LinearLayout>

    <!-- نص الرسالة -->
    <TextView
        android:id="@+id/tvBody"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="نص الرسالة..."
        android:textColor="#CCCCCC"
        android:textSize="13sp"
        android:maxLines="3"
        android:ellipsize="end"
        android:layout_marginTop="6dp" />

    <!-- الصف السفلي: الثقة + أزرار -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:layout_marginTop="10dp">

        <TextView
            android:id="@+id/tvConfidence"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ثقة: 30%"
            android:textColor="#FF9800"
            android:textSize="11sp" />

        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <TextView
            android:id="@+id/btnClassify"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="تصنيف يدوي"
            android:textColor="#2196F3"
            android:textSize="12sp"
            android:padding="6dp"
            android:background="?attr/selectableItemBackground" />

        <TextView
            android:id="@+id/btnDismiss"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="تجاهل"
            android:textColor="#F44336"
            android:textSize="12sp"
            android:padding="6dp"
            android:layout_marginStart="8dp"
            android:background="?attr/selectableItemBackground" />
    </LinearLayout>

</LinearLayout>
